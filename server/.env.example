# Server Configuration
PORT=3000

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/et-gen-ai

# GROQ API (for AI news processing)
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Google Gemini API (for chat and mindmap)
GEMINI_API_KEY=your_gemini_api_key_here
CHAT_LLM_MODEL=gemini-2.5-flash

# NewsData.io API
NEWS_API_KEY=your_newsdata_api_key_here

# Kling AI API (for video generation)
KLING_ACCESS_KEY=your_kling_access_key
KLING_SECRET_KEY=your_kling_secret_key
KLING_API_URL=https://api-singapore.klingai.com/v1/videos/text2video
KLING_API_QUERY_URL=https://api-singapore.klingai.com

# Default News Settings
CATEGORY=Technology
LANGUAGE=en
REGION=in