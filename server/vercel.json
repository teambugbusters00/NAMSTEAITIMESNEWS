{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/news/fetch",
      "dest": "/index.js"
    },
    {
      "src": "/api/auth/sync",
      "dest": "/index.js"
    },
    {
      "src": "/api/auth/verify",
      "dest": "/index.js"
    },
    {
      "src": "/api/chat/chat",
      "dest": "/index.js"
    },
    {
      "src": "/api/video/capabilities",
      "dest": "/index.js"
    },
    {
      "src": "/api/video/create",
      "dest": "/index.js"
    },
    {
      "src": "/api/video/tasks/list",
      "dest": "/index.js"
    },
    {
      "src": "/api/video/(.*)",
      "dest": "/index.js"
    },
    {
      "src": "/api/mindmap/generate",
      "dest": "/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ]
}